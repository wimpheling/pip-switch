<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>dev.pip-switch.daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Applications/pip-switch.app/Contents/MacOS/pip-switch-daemon</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/tmp/pip-switch-daemon.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/pip-switch-daemon.err</string>
</dict>
</plist>
